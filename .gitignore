# Byte-compiled / caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
.venv-*/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
.env
.env.*

# Weights & Biases (if enabled)
wandb/

# Experiment outputs under results/: ignore heavy artifacts, keep small summaries
results/logs/
results/**/logs/
results/**/logs/**
results/checkpoints/
results/**/checkpoints/
results/**/checkpoints/**
results/models/
results/**/*.ckpt
results/**/*.pth
results/**/*.pt
results/**/Predictions_*.npz

# Keep lightweight aggregate outputs
!results/tables/
!results/tables/*.csv
!results/**/*.meta.json

# Artifacts: ignore heavy bundles/arrays, keep metadata
artifacts/*.pt
artifacts/*.npz
!artifacts/*.json
!artifacts/*.meta.json

# ICU-Sepsis bundle: optional large CSV tables (~1.7 MB); MDP uses packaged dynamics.npz
icu_sepsis/icu-sepsis-csv-tables.tar.gz

# Duplicate of icu_sepsis/icu_sepsis + icu_sepsis_helpers (upstream "packages/" layout)
icu_sepsis/packages/

# Redundant notebook; canonical copy is notebooks/icu_sepsis_demo.ipynb
icu_sepsis/demo.ipynb

# Generated notebook outputs (GIFs, etc.)
icu_sepsis/demo_outputs/
notebooks/demo_outputs/
